{
  "compilerOptions": {
    /* File Layout */
    "rootDir": "./src",
    "outDir": "./dist",

    /* Environment Settings */
    "module": "CommonJS",
    "moduleResolution": "node10",
    "target": "es2023",
    "lib": ["esnext"],
    "types": ["node"],

    /* Other Outputs */
    "sourceMap": true,
    "declaration": true,
    "declarationMap": true,

    /* Typechecking Options - এরর কমাতে এগুলো শিথিল করা হয়েছে */
    "strict": false,
    "noImplicitAny": false,
    "noUncheckedIndexedAccess": false,

    /* Recommended Options */
    "esModuleInterop": true,
    "isolatedModules": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}