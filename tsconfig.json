{
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    "module": "CommonJS",
    "moduleResolution": "node",
    "target": "es2023",
    "lib": ["esnext"],
    "types": ["node"],

    /* এই লাইনটি একদম নিশ্চিত করো আছে কি না */
    "ignoreDeprecations": "5.0", 

    "strict": false,
    "noImplicitAny": false,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "isolatedModules": true
  },
  "include": ["src/**/*"],
  "exclude": ["node_modules", "dist"]
}